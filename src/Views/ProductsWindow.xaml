<Window x:Class="fishapp.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:fishapp"
        mc:Ignorable="d"
        Title="Каталог товаров" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="{StaticResource AccentBrush}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
               
                <Image x:Name="LogoImage" Grid.Column="0" Width="50" Height="50" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed"/>
                
                <TextBlock Grid.Column="1" Text="Каталог товаров" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock x:Name="UserInfo" Text="" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button x:Name="BackButton" Content="Назад" Click="BackButton_Click" Width="100" Margin="5,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="SearchTextBox" Width="300" TextChanged="SearchTextBox_TextChanged" VerticalContentAlignment="Center"/>
                <Label Content="Сортировка:" VerticalAlignment="Center" Margin="20,0,5,0"/>
                <ComboBox x:Name="SortComboBox" Width="200" SelectionChanged="SortComboBox_SelectionChanged">
                    <ComboBoxItem Content="По наименованию (А-Я)" IsSelected="True"/>
                    <ComboBoxItem Content="По наименованию (Я-А)"/>
                    <ComboBoxItem Content="По цене (возрастание)"/>
                    <ComboBoxItem Content="По цене (убывание)"/>
                    <ComboBoxItem Content="По категории"/>
                </ComboBox>
                <Label Content="Категория:" VerticalAlignment="Center" Margin="20,0,5,0"/>
                <ComboBox x:Name="CategoryFilterComboBox" Width="200" SelectionChanged="CategoryFilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="Все категории" IsSelected="True"/>
                </ComboBox>
            </StackPanel>
            
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Label Content="Производитель:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="ManufacturerFilterComboBox" Width="200" SelectionChanged="ManufacturerFilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="Все производители" IsSelected="True"/>
                </ComboBox>
                <Label Content="Поставщик:" VerticalAlignment="Center" Margin="20,0,5,0"/>
                <ComboBox x:Name="SupplierFilterComboBox" Width="200" SelectionChanged="SupplierFilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="Все поставщики" IsSelected="True"/>
                </ComboBox>
                <Button x:Name="ClearFiltersButton" Content="Сбросить фильтры" Click="ClearFiltersButton_Click" Margin="20,0,0,0" Padding="10,5"/>
            </StackPanel>
        </Grid>
        
        <ListBox Grid.Row="2" x:Name="ProductsListBox" 
                 SelectionChanged="ProductsListBox_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 BorderThickness="0"
                 Background="Transparent"
                 SelectionMode="Single">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="ItemBorder" Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#FFE8F4F8"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#FFF0F8FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="ProductCard" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2" Margin="5" Padding="10" Background="{StaticResource MainBackgroundBrush}" 
                            MouseLeftButtonDown="ProductItem_MouseLeftButtonDown" Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Margin="0,0,5,0" Background="{StaticResource MainBackgroundBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <Border Grid.Row="0" Background="{StaticResource AdditionalBackgroundBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Padding="5" HorizontalAlignment="Left" VerticalAlignment="Top" Width="100">
                                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" FontSize="12">
                                            <TextBlock.Text>
                                                <Binding Path="Sale"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        </Border>

                                        <Grid Grid.Row="1" Margin="5">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Наименование | Категория:" FontWeight="Bold" Margin="0,0,5,0" FontSize="11"/>
                                                <TextBlock TextWrapping="Wrap" FontSize="11">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} | {1}">
                                                            <Binding Path="Name"/>
                                                            <Binding Path="CategoryName"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Производитель:" FontWeight="Bold" Margin="0,0,5,0" FontSize="11"/>
                                                <TextBlock Text="{Binding ManufacturerName}" TextWrapping="Wrap" FontSize="11"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Поставщик:" FontWeight="Bold" Margin="0,0,5,0" FontSize="11"/>
                                                <TextBlock Text="{Binding SupplierName}" TextWrapping="Wrap" FontSize="11"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Количество на складе:" FontWeight="Bold" Margin="0,0,5,0" FontSize="11"/>
                                                <TextBlock TextWrapping="Wrap" FontSize="11">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} {1}">
                                                            <Binding Path="Count"/>
                                                            <Binding Path="Unit"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Row="4">
                                                <TextBlock Text="Описание:" FontWeight="Bold" Margin="0,0,0,3" FontSize="11"/>
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="11" MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                                
                                <Border Grid.Column="2" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Background="{StaticResource MainBackgroundBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <Border Grid.Row="0" Background="{StaticResource AdditionalBackgroundBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Padding="5">
                                            <TextBlock HorizontalAlignment="Center" FontWeight="Bold" FontSize="12">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} ₽ / {1}">
                                                        <Binding Path="Price"/>
                                                        <Binding Path="Unit"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                        
                                        <Border Grid.Row="1" Background="{StaticResource AdditionalBackgroundBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" MinHeight="150">
                                            <Grid>
                                                <Image Source="{Binding ImageSource}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="200" MaxHeight="200"/>
                                                <TextBlock Text="ФОТО" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="18">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ImageSource}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBoxItem}}, Path=IsSelected}" Value="True">
                                <Setter TargetName="ProductCard" Property="Background" Value="#FFD0E8F0"/>
                                <Setter TargetName="ProductCard" Property="BorderBrush" Value="#FF4A90E2"/>
                                <Setter TargetName="ProductCard" Property="BorderThickness" Value="3"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        
        <Border Grid.Row="3" Background="{StaticResource AdditionalBackgroundBrush}" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ViewDetailsButton" Content="Просмотр деталей" Click="ViewDetailsButton_Click" Width="150" Margin="0,0,10,0" IsEnabled="False"/>
                <Button x:Name="AddProductButton" Content="Добавить товар" Click="AddProductButton_Click" Width="150" Margin="0,0,10,0" Visibility="Collapsed"/>
                <Button x:Name="EditProductButton" Content="Редактировать" Click="EditProductButton_Click" Width="150" Margin="0,0,10,0" Visibility="Collapsed"/>
                <Button x:Name="DeleteProductButton" Content="Удалить" Click="DeleteProductButton_Click" Width="150" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

