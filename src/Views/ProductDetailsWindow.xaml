<Window x:Class="fishapp.ProductDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Детали товара" Height="350" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource MainBackgroundBrush}">
    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="129.317"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource AccentBrush}" Padding="10" Margin="0,0,0,121" Grid.RowSpan="3">
            <StackPanel Orientation="Horizontal">
                <Image x:Name="LogoImage" Width="50" Height="50" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <Grid Margin="10,10,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Margin="0,0,5,0" Background="{StaticResource MainBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource AdditionalBackgroundBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Padding="10" HorizontalAlignment="Left" VerticalAlignment="Top" Width="150">
                        <TextBlock x:Name="SaleText" Text="Скидка" HorizontalAlignment="Center" FontWeight="Bold"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Наименование | Категория:" FontWeight="Bold" Margin="0,0,5,0"/>
                            <TextBlock x:Name="NameCategoryText" Text="" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Производитель:" FontWeight="Bold" Margin="0,0,5,0"/>
                            <TextBlock x:Name="ManufacturerText" Text="" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Поставщик:" FontWeight="Bold" Margin="0,0,5,0"/>
                            <TextBlock x:Name="SupplierText" Text="" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Количество на складе:" FontWeight="Bold" Margin="0,0,5,0"/>
                            <TextBlock x:Name="CountText" Text="" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="Описание:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                <TextBlock x:Name="DescriptionText" Text="" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Background="{StaticResource MainBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource AdditionalBackgroundBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Padding="10">
                        <TextBlock x:Name="PriceText" Text="" HorizontalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource AdditionalBackgroundBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                        <Grid>
                            <Image x:Name="ProductImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="300" MaxHeight="400"/>
                            <TextBlock x:Name="PhotoPlaceholderText" Text="ФОТО" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="24" Visibility="Visible"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="51*"/>
                    <RowDefinition Height="47*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,102" Grid.RowSpan="2">
                    <Button x:Name="EditButton" Content="Редактировать" Click="EditButton_Click" Width="150" Margin="0,0,10,0" Visibility="Collapsed"/>
                    <Button x:Name="SaveButton" Content="Сохранить" Click="SaveButton_Click" Width="150" Margin="0,0,10,0" Visibility="Collapsed"/>
                    <Button x:Name="CancelButton" Content="Отмена" Click="CancelButton_Click" Width="150" Margin="0,0,10,0" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>

