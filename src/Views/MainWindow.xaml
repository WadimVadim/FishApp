<Window x:Class="fishapp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:fishapp"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800"
        Background="{StaticResource MainBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="{StaticResource AccentBrush}" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Image x:Name="LogoImage" Width="50" Height="50" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed"/>
                <TextBlock Text="Авторизация" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="150" x:Name="Login"></TextBox>
                <Label Content="Логин"></Label>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 5 0 0">
                <PasswordBox Width="150" x:Name="Pass"></PasswordBox>
                <Label Content="Пароль"></Label>
            </StackPanel>
            <StackPanel Margin="0 5 0 0">
                <Button Width="150" Click="LoginClick"  Content="Войти"></Button>
            </StackPanel>
            <StackPanel Margin="0 5 0 0">
                <Button Width="150" Click="GuestClick" Content="Войти как гость"></Button>
            </StackPanel>
            <StackPanel Margin="0 5 0 0">
                <Button Width="150" Click="ExitClick" Content="Выйти"></Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
